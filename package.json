{
  "name": "sentence-miner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "mpv subtitle mining helper with a live local transcript site and AnkiConnect integration.",
  "scripts": {
    "build:helper": "node scripts/build-helper.mjs",
    "package:release": "node scripts/package-release.mjs",
    "start": "node --experimental-strip-types src/main.ts",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "esbuild": "^0.25.2",
    "ffmpeg-static": "^5.3.0",
    "lucide-static": "^1.8.0",
    "postject": "^1.0.0-alpha.6"
  }
}
